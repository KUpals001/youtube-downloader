# Optional: Deezer API key (for higher rate limits / identified requests)
# Get one at https://developers.deezer.com/
# DEEZER_API_KEY=your_deezer_app_access_token

# Optional: Discogs token for metadata (https://www.discogs.com/settings/developers)
# DISCOGS_TOKEN=your_discogs_token

# Database (Prisma)
# DATABASE_URL="file:./data/ytdl.db"

# Optional: Path to ffmpeg/ffprobe if not in PATH
# FFMPEG_LOCATION=/path/to/ffmpeg/dir

# Optional: Path to yt-dlp if not in PATH
# YTDLP_PATH=yt-dlp

# Optional: Enable debug logging
# DEBUG=true
